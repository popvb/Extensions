п»ї{"id":"animewaku-onlinestream","name":"AnimeWaku","version":"1.0.0","manifestURI":"","language":"javascript","type":"onlinestream-provider","description":"Thai subbed (аё‹аё±аёља№„аё—аёў) and dubbed (аёћаёІаёЃаёўа№Ња№„аё—аёў) anime streaming from AnimeWaku.com","author":"opencode","icon":"https://www.animewaku.com/favicon.ico","website":"","readme":"","lang":"th","payload":"/// \u003creference path=\"./online-streaming-provider.d.ts\" /\u003e\n\nclass Provider {\n  constructor() {\n    this.base = \"https://www.animewaku.com\";\n    this.searchApi = \"https://www.animewaku.com/wp-json/dooplay/search/\";\n    this.playerApi = \"https://www.animewaku.com/wp-json/dooplayer/v1/post\";\n    this.ua = \"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36\";\n  }\n\n  getSettings() {\n    return {\n      episodeServers: [\"Г ВёВ«Г ВёВҐГ ВёВ±Г ВёВЃ\", \"Г ВёВЄГ ВёВіГ ВёВЈГ ВёВ­Г ВёвЂЎ1\", \"Г ВёВЄГ ВёВіГ ВёВЈГ ВёВ­Г ВёвЂЎ2\"],\n      supportsDub: true,\n    };\n  }\n\n  async getNonce() {\n    const res = await fetch(this.base + \"/\", {\n      headers: { \"User-Agent\": this.ua },\n    });\n    const html = await res.text();\n    const m = html.match(/\"nonce\":\"([^\"]+)\"/);\n    if (!m) throw new Error(\"Failed to extract nonce\");\n    return m[1];\n  }\n\n  async search(opts) {\n    const nonce = await this.getNonce();\n    const res = await fetch(this.searchApi + \"?keyword=\" + encodeURIComponent(opts.query) + \"\u0026nonce=\" + nonce, {\n      headers: { \"User-Agent\": this.ua, \"Referer\": this.base + \"/\" },\n    });\n    if (!res.ok) return [];\n    const data = await res.json();\n    const results = [];\n\n    for (const key in data) {\n      const item = data[key];\n      if (!item.url || !item.title) continue;\n\n      const slug = item.url.replace(/\\/$/, \"\").split(\"/\").pop();\n      if (!slug) continue;\n\n      const title = item.title;\n      const lower = title.toLowerCase();\n\n      let subOrDub = \"sub\";\n      if (lower.indexOf(\"Г ВёЕѕГ ВёВІГ ВёВЃГ ВёВўГ В№Е’Г В№вЂћГ ВёвЂ”Г ВёВў\") \u003e= 0) {\n        subOrDub = lower.indexOf(\"Г ВёвЂ№Г ВёВ±Г ВёЕЎГ В№вЂћГ ВёвЂ”Г ВёВў\") \u003e= 0 ? \"both\" : \"dub\";\n      }\n\n      results.push({\n        id: slug,\n        title: title,\n        url: item.url,\n        subOrDub: subOrDub,\n      });\n    }\n\n    if (!results.length) throw new Error(\"No anime found\");\n    return results;\n  }\n\n  async findEpisodes(id) {\n    const url = id.indexOf(\"http\") === 0 ? id : this.base + \"/anime/\" + id + \"/\";\n    const res = await fetch(url, {\n      headers: { \"User-Agent\": this.ua, \"Accept\": \"text/html,application/xhtml+xml\" },\n    });\n    if (!res.ok) throw new Error(\"Failed to fetch anime page\");\n    const html = await res.text();\n    const episodes = [];\n\n    const liRegex = /\u003cli[^\u003e]*\u003e([\\s\\S]*?)\u003c\\/li\u003e/g;\n    let m;\n    while ((m = liRegex.exec(html)) !== null) {\n      const li = m[1];\n      const linkMatch = li.match(/\u003ca[^\u003e]*href=\"(https?:\\/\\/www\\.animewaku\\.com\\/ep\\/(\\d+)\\/)\"[^\u003e]*\u003e([\\s\\S]*?)\u003c\\/a\u003e/);\n      if (!linkMatch) continue;\n\n      const epUrl = linkMatch[1];\n      const epId = linkMatch[2];\n      const linkContent = linkMatch[3];\n\n      const numMatch = li.match(/\u003cspan class=\"numerando\"\u003e([\\s\\S]*?)\u003c\\/span\u003e/);\n      let number = 0;\n      if (numMatch) {\n        const parts = numMatch[1].trim().split(/\\s*-\\s*/);\n        if (parts.length \u003e= 2) number = parseInt(parts[parts.length - 1].trim());\n      }\n      if (!number) {\n        const epNumMatch = linkContent.match(/Г ВёвЂўГ ВёВ­Г Вёв„ўГ ВёвЂ”Г ВёВµГ В№Л†\\s*(\\d+)/);\n        if (epNumMatch) number = parseInt(epNumMatch[1]);\n      }\n\n      const title = linkContent.replace(/\u003c[^\u003e]+\u003e/g, \"\").trim();\n      episodes.push({\n        id: epId,\n        title: title || (\"Episode \" + number),\n        number: number || episodes.length + 1,\n        url: epUrl,\n      });\n    }\n\n    if (!episodes.length) throw new Error(\"No episodes found\");\n    episodes.sort((a, b) =\u003e a.number - b.number);\n    return episodes;\n  }\n\n  async findEpisodeServer(episode, server) {\n    const serverMap = { \"Г ВёВ«Г ВёВҐГ ВёВ±Г ВёВЃ\": \"1\", \"Г ВёВЄГ ВёВіГ ВёВЈГ ВёВ­Г ВёвЂЎ1\": \"2\", \"Г ВёВЄГ ВёВіГ ВёВЈГ ВёВ­Г ВёвЂЎ2\": \"3\" };\n    const source = (server \u0026\u0026 server !== \"default\" \u0026\u0026 serverMap[server]) ? serverMap[server] : \"1\";\n\n    const res = await fetch(this.playerApi + \"/\" + episode.id + \"?type=tv\u0026source=\" + source, {\n      headers: {\n        \"User-Agent\": this.ua,\n        \"Referer\": this.base + \"/ep/\" + episode.id + \"/\",\n        \"X-Requested-With\": \"XMLHttpRequest\",\n        \"Accept\": \"application/json, text/javascript, */*; q=0.01\",\n      },\n    });\n    if (!res.ok) throw new Error(\"Failed to fetch video source\");\n    const data = await res.json();\n    if (!data.embed_url) throw new Error(\"No embed URL found\");\n\n    let videoUrl = data.embed_url;\n    let videoType = \"hls\";\n\n    try {\n      const embedRes = await fetch(data.embed_url, {\n        headers: { \"Referer\": this.base + \"/\", \"User-Agent\": this.ua },\n      });\n      if (embedRes.ok) {\n        const embedHtml = await embedRes.text();\n        const m3u8Match = embedHtml.match(/https?:\\/\\/[^\"\u0027\\s\u003c\u003e]+\\.m3u8[^\"\u0027\\s\u003c\u003e]*/);\n        if (m3u8Match) {\n          videoUrl = m3u8Match[0];\n        } else {\n          const iframeMatch = embedHtml.match(/\u003ciframe[^\u003e]*src=\"([^\"]+)\"/);\n          if (iframeMatch) {\n            videoUrl = iframeMatch[1];\n            videoType = \"unknown\";\n          }\n        }\n      }\n    } catch (e) {\n      // use embed URL directly\n    }\n\n    return {\n      server: server || \"Г ВёВ«Г ВёВҐГ ВёВ±Г ВёВЃ\",\n      headers: { \"Referer\": data.embed_url, \"User-Agent\": this.ua },\n      videoSources: [{ url: videoUrl, quality: \"auto\", type: videoType, subtitles: [] }],\n    };\n  }\n}\n"}
